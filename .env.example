# ─── API KEYS ───────────────────────────────────────────────
# YouTube Data API v3 (gratis, 10k unidades/día)
# Obtener en: https://console.cloud.google.com
YOUTUBE_API_KEY=

# Twitter/X Bearer Token
# Obtener en: https://developer.twitter.com
TWITTER_BEARER_TOKEN=

# Apify (scraping escalable - opcional)
APIFY_TOKEN=

# ─── APP ────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=cambiar-esto-en-produccion

# ─── BASE DE DATOS ──────────────────────────────────────────
# SQLite para desarrollo local
DATABASE_URL=sqlite:///./diagonales.db

# PostgreSQL para producción (descomentar cuando escales)
# DATABASE_URL=postgresql://user:password@localhost/diagonales

# ─── SCHEDULER ──────────────────────────────────────────────
TIMEZONE=America/Argentina/Buenos_Aires
RSS_INTERVAL_HOURS=2
YOUTUBE_HOURS=6,12,18,23
REPORT_HOURS=7,19
